                </mxCell>
                <mxCell id="wf-note" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;Issue Management &amp;amp; Validation — Key Steps Summary&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;font style=&quot;line-height: 220%;&quot;&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-size: 15px;&quot;&gt;1. RCA:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-size: 15px;&quot;&gt; Assessor performs Root Cause Analysis addressing the 4Cs.&lt;/span&gt;&lt;/div&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;2–4. Formulate:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Issue Write-Up, CMIR creation, Severity rating in CRC.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;5. Assign:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Issue Owner designated; record opened in iCAPS.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;6–7. Report:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Review Manager reviews, issues Draft Report within 7 days.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;8–9. CAP:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Business develops &amp;amp; submits all four CAP types to iCAPS.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;10. Validate:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Validation Assessor independently validates within 30 days.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;11. Outcome:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Close, Special Closure, or Re-Open in iCAPS.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;SLAs:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Draft Report = 7 calendar days | CAP Validation = 30 calendar days&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;System:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; All activities documented in CRC-ICRM (CSI: 176046)&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=center;spacingLeft=8;spacingRight=8;" parent="1" vertex="1">
                    <mxGeometry x="355" y="1640" width="585" height="350" as="geometry"/>
                </mxCell>
                <mxCell id="actor-note" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;line-height: 220%;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;Actors &amp;amp; Roles&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-size: 15px; line-height: 220%;&quot;&gt;&lt;b&gt;Assessor (ICRM Staff)&lt;/b&gt;&lt;/span&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-size: 15px; line-height: 220%;&quot;&gt;:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-size: 15px; line-height: 220%;&quot;&gt; Performs RCA, formulates issues, creates CMIR, tracks to completion.&lt;/span&gt;&lt;/div&gt;&lt;b style=&quot;font-size: 15px; line-height: 220%;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;Review Manager:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Reviews issue &amp;amp; CMIR, issues Draft Report within 7 calendar days.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px; line-height: 220%;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;Issue Owner (Business):&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Receives report, develops all CAP types, executes remediation.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px; line-height: 220%;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;SME:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Engaged optionally to provide expert regulatory or policy opinion.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px; line-height: 220%;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;Validation Assessor:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Independently validates CAP within 30 calendar days.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;b style=&quot;font-size: 15px; line-height: 220%;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;CRC-ICRM System:&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent; font-weight: normal;&quot;&gt; Central system — stores CMIR, manages iCAPS records, tracks lifecycle.&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#EBF5FB;strokeColor=#2E86C1;align=center;spacingLeft=8;spacingRight=8;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="1640" width="750" height="320" as="geometry"/>
                </mxCell>
