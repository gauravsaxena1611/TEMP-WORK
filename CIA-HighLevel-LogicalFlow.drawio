                <mxCell id="mod-planning" value="&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;(1) Annual Planning &amp;amp; Scoping Module&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• Identify Planning Units (PUs) &amp;amp; ICRM Assessment Entities (AEs)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Identify Significant Compliance Risks (SCRs) via CRC-CRA&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Develop Risk-Based Annual Coverage Plan (Monitoring &amp;amp; Testing)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Share Plan with Compliance Officers — End of Q1 | Updated Periodically&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#666666;" parent="processing-section" vertex="1">
                    <mxGeometry x="433" y="120" width="555" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="mod-monitoring" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;(2) Compliance Monitoring Module&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• Design Monitoring Assessment Activities (Objective, Procedure Steps, Outcomes)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(85, 85, 85); font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Execute Monitoring (Ongoing, Agile, Proactive — Potential Weakness Detection)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Document Workpapers in ICRM Monitoring Module within CRC&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Review Manager Approval / Sign-Off Captured in CRC&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#D4E6F1;strokeColor=#2E86C1;" parent="processing-section" vertex="1">
                    <mxGeometry x="49.75" y="360" width="581.5" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="mod-testing" value="&lt;span style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;(3) Compliance Testing Module&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;/span&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• Scope Review — L1-L2 Risks, LRRPs, Legal Entities, Objectives&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;• Create Review Planning Document (RPD) in CRC&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;• Design Review Work Program (RWP) — Sampling / 100% / Controls Testing&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span&gt;• Execute Tests &amp;amp; Document Workpapers (Walkthroughs, Evidence, Narratives)&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#D5F5E3;strokeColor=#239B56;fontColor=#666666;labelBackgroundColor=none;" parent="processing-section" vertex="1">
