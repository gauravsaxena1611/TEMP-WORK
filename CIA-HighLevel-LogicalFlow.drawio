                <mxCell id="mod-reporting" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Reporting Module&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• CMIR — Compliance Monitoring Issue Report&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(85, 85, 85); font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Draft Reports, Metrics &amp;amp; Dashboards&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5DBDB;strokeColor=#424949;" parent="processing-section" vertex="1">
