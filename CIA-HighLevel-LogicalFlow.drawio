                <mxCell id="mod-issue-mgmt" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;(4) Issue Management Module&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• Root Cause Analysis (RCA) — 4Cs: Concern, Cause, Consequence, Context&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(85, 85, 85); font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Create CMIR in CRC &amp;amp; Determine Issue Severity — Assign Issue Owner&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Obtain Corrective Action Plan (CAP): &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Planning / Compensating / Remediation / Sustainability&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Issue Draft Report within 7 Calendar Days of Test Execution End Date&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#E8DAEF;strokeColor=#7D3C98;" parent="processing-section" vertex="1">
                    <mxGeometry x="54" y="767.5" width="573" height="135" as="geometry"/>
                </mxCell>
                <mxCell id="mod-validation" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;(5) Issue Validation Module&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• Track All Issues to Completion — Issue Validation Module (CRC)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(85, 85, 85); font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Validate Completed CAP within 30 Calendar Days of CAP Target Date&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Successful Validation = Issue Closed | Failed Validation = Re-Open in iCAPS&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;• Issue Closure Without Validation (Issue Avoidance / Transfer) if Applicable&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#FDEDEC;strokeColor=#E74C3C;" parent="processing-section" vertex="1">
