#!/bin/sh
# Maven Wrapper for Unix/Mac
# Bootstraps Maven 3.9.6 on first run — no global Maven install needed.

MAVEN_PROJECTBASEDIR="$(dirname "$0")"
WRAPPER_DIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"
DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper..."
    if command -v curl > /dev/null; then
        curl -o "$WRAPPER_JAR" "$DOWNLOAD_URL"
    elif command -v wget > /dev/null; then
        wget -O "$WRAPPER_JAR" "$DOWNLOAD_URL"
    else
        echo "ERROR: curl or wget required to download Maven wrapper"
        exit 1
    fi
fi

exec java -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" -classpath "$WRAPPER_JAR" $WRAPPER_LAUNCHER "$@"
