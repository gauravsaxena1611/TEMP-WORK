                <mxCell id="9" value="&lt;b style=&quot;color: rgb(63, 63, 63); text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;COI Workflow Steps&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;color: rgb(63, 63, 63); font-size: 11px; text-align: left; line-height: 160%;&quot;&gt;1.&amp;nbsp;&lt;b&gt;Initiate:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Any Citi employee logs into GCOI UI, creates &amp;amp; saves a new COI record&lt;br&gt;&amp;nbsp; &amp;nbsp;&lt;u&gt;EMAIL triggered&lt;/u&gt; → Employee&#39;s Business Risk &amp;amp; Control Team notified&lt;br&gt;&lt;br&gt;2.&amp;nbsp;&lt;b&gt;Enrich:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Risk &amp;amp; Control Team logs in, enriches COI with MCAs, policies &amp;amp; ref data;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Submits COI for CIBA review&lt;br&gt;&lt;br&gt;3. &lt;b&gt;CIBA&amp;nbsp;Check (Review &amp;amp; Credible Challenge):&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;CIBA Team verifies details, cross-references &amp;amp; challenges assumptions;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Accept → COI becomes &lt;b&gt;Active &amp;amp; Ongoing&lt;/b&gt; (placed on Watch List)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Return → Sent back to Business Team with correction notes&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;u&gt;EMAIL triggered&lt;/u&gt; → Business Team notified for rework&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Business Team updates &amp;amp; resubmits → returns to Step 3&lt;br&gt;&lt;br&gt;4.&amp;nbsp;&lt;b&gt;Retire:&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;When conflict is resolved, COI is Retired / Eliminated from active inventory&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Actors&lt;/b&gt;: Initiator | Enricher (Risk &amp;amp; Control) | Checker (CIBA)&lt;br&gt;&lt;b&gt;Statuses&lt;/b&gt;: Draft | Under Review | Active &amp;amp; Ongoing | Returned | Retired&lt;br&gt;&lt;b&gt;CIBA&lt;/b&gt;: Conflicts &amp;amp; Information Barrier Advisory Team&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;spacingLeft=7;spacingRight=7;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="250" width="460" height="475" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="" style="endArrow=none;dashed=1;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;edgeStyle=orthogonalEdgeStyle;" parent="1" source="coi-db" target="10" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="870" y="790" as="sourcePoint"/>
                        <mxPoint x="920" y="740" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
