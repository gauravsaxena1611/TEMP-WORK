                <mxCell id="rev-annplan" value="&lt;b&gt;1. Create Annual Plan&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 58, 92);&quot;&gt;Coverage of ICRM AEs, legal entities,&lt;br&gt;regulations, policies, GRC Risk Taxonomies;&lt;br&gt;Annual/Quarterly planning; Planning dashboards&lt;br&gt;(Entity, Regulation, Composite);&lt;br&gt;Review planning &amp;amp; scheduling workflow dates&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#9DC3E6;strokeColor=#2E86C1;fontColor=#1A3A5C;" parent="lane-rev-mgr" vertex="1">
                    <mxGeometry x="170" y="30" width="205" height="150" as="geometry"/>
