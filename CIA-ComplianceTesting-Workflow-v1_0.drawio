                <mxCell id="lane-cto" value="Compliance Testing&#xa;Officer (CTO)" style="swimlane;startSize=140;fillColor=#D5F5E3;strokeColor=#239B56;fontSize=13;fontStyle=1;horizontal=0;swimlaneHead=0;fontColor=#1A1A1A;" parent="1" vertex="1">
