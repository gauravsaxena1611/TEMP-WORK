                </mxCell>
                <mxCell id="ct-sub" value="&lt;b&gt;10. Substantive Testing&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A5C32;&#39;&gt;Transaction Based Testing;&lt;br/&gt;100% examination or Sampling;&lt;br/&gt;RPD to Substantive WP: 1-to-many;&lt;br/&gt;Includes End User Computing (EUC)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-cto" vertex="1">
