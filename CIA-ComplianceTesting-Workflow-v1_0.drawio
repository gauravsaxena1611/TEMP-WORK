                <mxCell id="ct-step3" value="&lt;b&gt;3. Initial Scoping&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 92, 50);&quot;&gt;PF ICRM Initial Scoping Meeting;&lt;br&gt;Document Minute of Meetings that CTOs&lt;br&gt;have for this review;&lt;br&gt;Review tagged to relevant L1 &amp;amp; L2 Risks&lt;br&gt;&amp;amp; in-scope LRRPs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-cto" vertex="1">
                    <mxGeometry x="310" y="106" width="185" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="ct-step4" value="&lt;b&gt;4. RAM&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 92, 50);&quot;&gt;Review Announcement Memo:&lt;br&gt;Prepare &amp;amp; send memo to Accountable&lt;br&gt;Business Executives &amp;amp; Stakeholders;&lt;br&gt;Document Minute of Meetings&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-cto" vertex="1">
                    <mxGeometry x="680" y="106" width="185" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="ct-step5" value="&lt;b&gt;5. Opening Meeting&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 92, 50);&quot;&gt;Prepare &amp;amp; send Opening Meeting Deck to&lt;br&gt;stakeholders; schedule Opening Meeting&lt;br&gt;via Outlook;&lt;br&gt;Present to Accountable Business Executives&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-cto" vertex="1">
                    <mxGeometry x="925" y="106" width="195" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="ct-step6" value="&lt;b&gt;6. RPD (Review Planning Document)&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 92, 50);&quot;&gt;Finalization of coverage &amp;amp; scope: Assessment&lt;br&gt;Entities, Obligations, Policies, Actionable Components;&lt;br&gt;Where CTOs create workpapers;&lt;br&gt;Identify Existing Issues;&lt;br&gt;Regulation Due Diligence (understanding LRRPs&lt;br&gt;&amp;amp; related business processes)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-cto" vertex="1">
                    <mxGeometry x="1170" y="86" width="230" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="rwp-group" value="&lt;b&gt;&lt;font style=&quot;font-size: 11px; color: rgb(26, 92, 50);&quot;&gt;7. Review Work Program (RWP)&lt;br&gt;Collection of workpapers tied to the Review; &lt;br&gt;RPD is the source (RPD-to-WP: 1-to-many)&lt;/font&gt;&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#C8E6C9;strokeColor=#239B56;verticalAlign=top;dashed=1;" parent="lane-cto" vertex="1">
                    <mxGeometry x="1450" y="35" width="570" height="270" as="geometry"/>
                </mxCell>
                <mxCell id="ct-dea" value="&lt;b&gt;8. DEA&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A5C32;&#39;&gt;Design Effectiveness&lt;br/&gt;Assessment&lt;br/&gt;(Control Design Based Testing)&lt;br/&gt;RPD to DEA: 1-to-many&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-cto" vertex="1">
                    <mxGeometry x="1468" y="119" width="155" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="ct-oet" value="&lt;b&gt;9. OET&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A5C32;&#39;&gt;Operating Effectiveness&lt;br/&gt;Testing&lt;br/&gt;(Control Based Testing in Operation)&lt;br/&gt;RPD to OET: 1-to-many&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-cto" vertex="1">
