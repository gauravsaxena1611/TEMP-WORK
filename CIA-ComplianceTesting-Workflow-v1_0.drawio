                <mxCell id="rev-rev-details" value="&lt;b&gt;2. Review Details&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 58, 92);&quot;&gt;High-level details of what this Review will test&lt;br&gt;and over what time frame; Review Details&lt;br&gt;approval workflow&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#9DC3E6;strokeColor=#2E86C1;fontColor=#1A3A5C;" parent="lane-rev-mgr" vertex="1">
                    <mxGeometry x="435" y="50" width="205" height="110" as="geometry"/>
