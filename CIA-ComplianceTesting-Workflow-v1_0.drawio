                <mxCell id="rev-approve-rpd" value="&lt;b&gt;Approve RPD&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A3A5C;&#39;&gt;Review and approve Review Planning Document;&lt;br/&gt;confirm coverage, scope &amp;amp; Actionable Components;&lt;br/&gt;approve or return for revision&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#9DC3E6;strokeColor=#2E86C1;fontColor=#1A3A5C;" parent="lane-rev-mgr" vertex="1">
                    <mxGeometry x="1270" y="60" width="185" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="rev-approve-rca" value="&lt;b&gt;Approve RCA&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A3A5C;&#39;&gt;Review and approve Root Cause Analysis;&lt;br/&gt;once approved, iCAPS Issue &amp;amp; CAPs&lt;br/&gt;are created (RCA-to-iCAPS: 1-to-1)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#9DC3E6;strokeColor=#2E86C1;fontColor=#1A3A5C;" parent="lane-rev-mgr" vertex="1">
                    <mxGeometry x="2220" y="55" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="rev-draft" value="&lt;b&gt;Issue Draft Report via CRC&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A3A5C;&#39;&gt;Formal report issued to stakeholders;&lt;br/&gt;create draft report; review with business&lt;/font&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#CC0000;&#39;&gt;&lt;b&gt;⏱ SLA: Within 7 Calendar Days of Execution End Date&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#9DC3E6;strokeColor=#2E86C1;fontColor=#1A3A5C;" parent="lane-rev-mgr" vertex="1">
                    <mxGeometry x="2556" y="55" width="195" height="95" as="geometry"/>
