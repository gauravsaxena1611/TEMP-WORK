                <mxCell id="mod-monitoring" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;(1) Compliance Monitoring Module&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• Scoping &amp;amp; Planning: &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Evaluates CRA results, Publications &amp;amp; Consumer Complaints; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Defines Procedure Scope — &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;AEs, GRC Risks, Policies, DSMT Segment &amp;amp; Geography&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(85, 85, 85); font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;• Design &amp;amp; Execution: &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Defines Procedure Steps &amp;amp; Expected Outcomes; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Conducts procedures; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Documents Exceptions Noted vs No Exceptions Found&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;• Issue Reports (CMIR): &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Raises Exceptions; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Creates CMIR in CRC; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Document Approval from Business; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Raises Issues/CAPs in iCAPS&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;• CMIR Outside Monitoring: &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Expedited Issue Report path — &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;without full Scoping/Design/Execution lifecycle&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#D4E6F1;strokeColor=#2E86C1;" parent="processing-section" vertex="1">
                    <mxGeometry x="237" y="114" width="620" height="380" as="geometry"/>
                </mxCell>
                <mxCell id="mod-testing" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;(2) Compliance Testing Module&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;• Annual Planning &amp;amp; Scoping: &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ICRM AEs, Legal Entities, Regulations, Policies; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;RAM (Review Announcement Memo); &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Opening Meeting; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;RPD (Review Planning Document)&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(85, 85, 85); font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;• Test Execution — Review Work Program (RWP): &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;DEA (Control Design Based Testing) | &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;OET (Control Operation Testing) | &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Substantive Testing (Transaction Based)&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;• Root Cause Analysis (RCA): &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Created from Exceptions — 4Cs (Concern, Cause, Consequence, Context); &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&quot;Raise Issue&quot; action triggers iCAPS Issue &amp;amp; CAP creation&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;• Reporting: &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Draft &amp;amp; Final Reports issued once workpapers approved; &lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Audit Logs &amp;amp; PDF Export; Issue Severity sent to iCAPS&lt;/div&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#D5F5E3;strokeColor=#239B56;fontColor=#666666;" parent="processing-section" vertex="1">
