                <mxCell id="title" value="&lt;b&gt;C4 Level 3 — Component Diagram&lt;/b&gt;&lt;br&gt;Container: CRA Rating Results Service (CNT-002)  ·  System: Compliance Risk Assessment (CSI-180236)&lt;br&gt;Audience: Developers and Architects  |  Phase 5 — Detailed Design  |  Last Verified: 2026-04-12" style="text;html=1;align=center;verticalAlign=middle;resizable=0;strokeColor=#cccccc;fillColor=#f8f8f8;fontSize=11;fontColor=#333333;rounded=1;" parent="1" vertex="1">
                    <mxGeometry y="5" width="1800" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="cnt-boundary" value="&lt;b&gt;CRA Rating Results Service&lt;/b&gt;  (Container Boundary — CNT-002)&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;Core calculation engine. Owns all systemic IR, CE, and RR publication-level calculations. Persists ratings to Assessment Store.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#2E86C1;strokeWidth=3;strokeDasharray=10 4;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#1A5276;" parent="1" vertex="1">
                    <mxGeometry x="390" y="120" width="1020" height="740" as="geometry"/>
                </mxCell>
                <mxCell id="cmp-ir" value="&lt;b&gt;Inherent Risk Calculator&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;&amp;lt;&amp;gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Implements Severity x Likelihood formula.&lt;br&gt;Aggregates Significance of Impact (4 MCA factors).&lt;br&gt;Applies severity tier adjustment (Very High bumps up; Low reduces).&lt;br&gt;Combines Complexity + Applicability + Business Activity&lt;br&gt;into overall likelihood. Produces publication IR Tier 1-5.&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ddeeff&quot;&gt;💡 Inferred from methodology sources&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5AA0;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="420" y="200" width="340" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="cmp-ce" value="&lt;b&gt;Control Environment Calculator&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;&amp;lt;&amp;gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Runs Strength of Controls decision tree on MCA design attributes (preventative/detective, automated/manual, frequency, missing controls).&lt;br&gt;Applies Control Effectiveness waterfall from ICAPS issue count and severity.&lt;br&gt;Produces publication CE rating: Effective / Partially Ineffective / Ineffective.&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ddeeff&quot;&gt;💡 Inferred from methodology sources&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5AA0;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="420" y="450" width="340" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="cmp-agg" value="&lt;b&gt;Aggregation Engine&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;&amp;lt;&amp;gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Rolls up publication-level IR and CE ratings&lt;br&gt;to L2 → L1 → overall GAU.&lt;br&gt;Applies Preparer qualitative overrides at L2/L1.&lt;br&gt;Implements highest-deficiency waterfall for CE aggregation.&lt;br&gt;Passes aggregated IR + CE to RR Matrix Engine.&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ddeeff&quot;&gt;💡 Inferred from methodology sources&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5AA0;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="820" y="200" width="340" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="cmp-rr" value="&lt;b&gt;Residual Risk Matrix Engine&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;&amp;lt;&amp;gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Applies the MCA GRC Residual Risk Matrix lookup.&lt;br&gt;Intersects IR Tier (1-5) and CE rating at every level:&lt;br&gt;publication, L2, L1, and overall GAU.&lt;br&gt;Output RR Tier is read-only to all user roles — no manual modification permitted.&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ddeeff&quot;&gt;✅ Confirmed from training transcript and methodology&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5AA0;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="820" y="450" width="340" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="cmp-val" value="&lt;b&gt;Validation Gate&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;&amp;lt;&amp;gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Tracks all mandatory fields across IR, CE, and Conclusion sections.&lt;br&gt;Maintains the validate counter displayed to the Preparer.&lt;br&gt;Hard block: submission is prevented while counter is greater than zero.&lt;br&gt;Receives notifications from Aggregation Engine as fields complete.&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ddeeff&quot;&gt;✅ Confirmed from training transcript&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0A3D6E;strokeColor=#072D50;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="620" y="710" width="560" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="ext-ui" value="&lt;b&gt;CRA UI&lt;/b&gt;&lt;br&gt;&lt;font&gt;[Container — CNT-001]&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;CRC Assessment Interface. Submits qualitative L2/L1 ratings and rationale from Preparer. Receives calculated publication ratings for display. Shows validate counter state.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#67AB9F;strokeColor=#4E8C82;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="20" y="310" width="300" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="ext-scoping" value="&lt;b&gt;Scoping Service&lt;/b&gt;&lt;br&gt;&lt;font&gt;[Container — CNT-003]&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Obligation Mapper component determines which publications are in scope per GAU. Provides scoped [publication x L2 risk stripe] pairs consumed by IR and CE Calculators.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#67AB9F;strokeColor=#4E8C82;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="20" y="560" width="300" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="ext-snapshot" value="&lt;b&gt;Snapshot Data Store&lt;/b&gt;&lt;br&gt;&lt;font&gt;[Data Store — CNT-006 / DS-002]&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Local on-premise store. Holds the reconciled annual snapshot of MCA, Reg Inventory, ICAPS, and PARCUM data. Read-only after data date (Oct 13, 2025 for 2025 cycle).&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#5A6A6A;strokeColor=#3D4A4A;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=center;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="20" y="800" width="300" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="ext-agg-svc" value="&lt;b&gt;Aggregation Service&lt;/b&gt;&lt;br&gt;&lt;font&gt;[Container — CNT-004]&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffffff&quot;&gt;Cross-GAU aggregation to country, regional, and global levels. Reads completed individual GAU ratings from this service for portfolio-level roll-up.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#67AB9F;strokeColor=#4E8C82;strokeWidth=2;fontSize=11;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
