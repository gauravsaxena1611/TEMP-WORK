                <mxCell id="leg_arr4" value="DB Operations (D1, D2, D3...)" style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;fontSize=11;fontColor=#7B7D7D;" parent="legend_bg" vertex="1">
