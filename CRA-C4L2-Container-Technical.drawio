                <mxCell id="cnt-003" value="&lt;b&gt;CRA Scoping Service&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#d0e8ff&quot;&gt;[API Service — CNT-003]&lt;br&gt;[Internal Microservice / Technology: TBD]&lt;/font&gt;&lt;br&gt;&lt;font&gt;Determines which publications are in scope for each GAU. 2025 change: obligation-based mapping replaces anchoring-risk scoping. One publication may appear multiple times across different L2 stripes.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5AA0;strokeWidth=2;fontSize=12;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="282" y="482" width="265" height="158" as="geometry"/>
                </mxCell>
                <mxCell id="cnt-004" value="&lt;b&gt;CRA Aggregation Service&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#d0e8ff&quot;&gt;[API Service — CNT-004]&lt;br&gt;[Internal Microservice / Technology: TBD]&lt;/font&gt;&lt;br&gt;&lt;font&gt;Post-calibration roll-up of completed GAU ratings to country, regional, and global levels. Risk-weighted average aggregation logic. Drives the governance reporting pipeline.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5AA0;strokeWidth=2;fontSize=12;fontColor=#ffffff;align=left;spacingLeft=8;verticalAlign=top;" parent="1" vertex="1">
