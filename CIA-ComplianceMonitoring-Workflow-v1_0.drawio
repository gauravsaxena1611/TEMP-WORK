                <mxCell id="cm-step1" value="&lt;b&gt;2. Scoping (Pre-Planning)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 92, 50);&quot;&gt;Define Procedure Scope: &lt;br&gt;AEs based on CRA ratings,&lt;br&gt;GRC Risks, Publications &amp;amp; Policies, DSMT Segment &amp;amp; Geography; &lt;br&gt;Coverage Reports &amp;amp; Dashboards&lt;br&gt;(AE, GRC Risk, Monitoring Drivers, Regs, Policies)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-preparer" vertex="1">
                    <mxGeometry x="200" y="20" width="185" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="cm-step2" value="&lt;b&gt;3. Planning&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A5C32;&#39;&gt;Define Procedure Ownership &amp;amp; Execution Timeline;&lt;br/&gt;Plan Workflow (Maker-Checker);&lt;br/&gt;Plan Reports: Quarterly &amp;amp; Annual;&lt;br/&gt;Adding MLEs, AUs, DSMT Geo to Procedure;&lt;br/&gt;AE Coverage; Clone/Deactivate Procedures;&lt;br/&gt;Audit Logs, PDF Export&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-preparer" vertex="1">
                    <mxGeometry x="445" y="20" width="185" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="cm-step3" value="&lt;b&gt;4. Design&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#1A5C32;&#39;&gt;Create Procedure Steps;&lt;br/&gt;Link GRC Activity;&lt;br/&gt;Link Application CSI ID / Vendor Details;&lt;br/&gt;Design Workflow (Maker-Checker);&lt;br/&gt;Add Business Controls;&lt;br/&gt;Design Enhancements: Third-Party Identifiers;&lt;br/&gt;Design Export&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-preparer" vertex="1">
                    <mxGeometry x="690" y="20" width="185" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="cm-step4" value="&lt;b&gt;5. Execution&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 92, 50);&quot;&gt;Execute monitoring procedures as designed;&lt;br&gt;Document Execution Outcome;&lt;br&gt;Log Exceptions; &lt;br&gt;Execute Execution Workflow;&lt;br&gt;Issue Cancellations &lt;br&gt;(revised action taken);&lt;br&gt;Upload Documentation post Cancellation;&lt;br&gt;Snapshot Historical Plan/Design/Attestations;&lt;br&gt;Generate Reports for Non-Responsive Routines;&lt;br&gt;Audit Logs, PDF Export&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#A9DFBF;strokeColor=#239B56;fontColor=#1A1A1A;" parent="lane-preparer" vertex="1">
