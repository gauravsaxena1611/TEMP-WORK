                <mxCell id="lane-preparer" value="Procedure Preparer&#xa;(ICRM Staff)" style="swimlane;startSize=140;fillColor=#D5F5E3;strokeColor=#239B56;fontSize=12;fontStyle=1;horizontal=0;swimlaneHead=0;fontColor=#1A1A1A;" parent="1" vertex="1">
