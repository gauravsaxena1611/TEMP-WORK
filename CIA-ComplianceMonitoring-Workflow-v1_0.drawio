                <mxCell id="coord-ec" value="&lt;b&gt;1a. ICRM EC Context Setup&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px; color: rgb(26, 58, 92);&quot;&gt;Select Planning Units (PUs); &lt;br&gt;Monitoring Unit;&lt;br&gt;Country of Execution; &lt;br&gt;Owner&#39;s Managed Geography;&lt;br&gt;Legal Entity aligned to Monitoring Execution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#AED6F1;strokeColor=#2E86C1;fontColor=#1A3A5C;" parent="lane-coord" vertex="1">
