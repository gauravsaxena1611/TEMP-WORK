                <mxCell id="e-coord-outside" value="CMIR Outside&lt;br&gt;Monitoring path" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#F9A825;fontSize=9;dashed=1;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="1" source="coord-outside" target="cm-step6" edge="1">
